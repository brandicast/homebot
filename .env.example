# ============================================================
# Homebot 環境變數設定範本
# 複製此檔案為 .env 並填入實際值
# 注意：.env 已加入 .gitignore，切勿 commit 實際機密資訊
# ============================================================

# ---- LINE Bot 設定 ----
LINE_CHANNEL_ID=your_channel_id_here
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_PORT=9111

# ---- AI 服務設定 ----
AI_ENABLE=true
AI_URL=http://127.0.0.1:8888/chat/id/

# ---- MQTT Broker 設定 ----
MQTT_ENABLE=true
MQTT_URL=mqtt://192.168.68.57
MQTT_PORT=1883
MQTT_CLIENT_ID=homebot
MQTT_TOPIC_FOR_IOT=brandon/iot/zwave/philio/event/#
MQTT_TOPIC_FOR_PICO=brandon/iot/pico/gate
MQTT_TOPIC_FOR_HOMEBOT=brandon/homebot/log
